{
  "name": "yt-forge",
  "productName": "YT-FORGE",
  "version": "1.0.0",
  "description": "A desktop YouTube video downloader powered by yt-dlp",
  "main": "dist-electron/main.js",
  "scripts": {
    "start": "concurrently -k \"vite --config vite.renderer.config.mjs\" \"wait-on http://localhost:5173 && electron .\"",
    "build:renderer": "vite build --config vite.renderer.config.mjs",
    "build:main": "vite build --config vite.main.config.mjs",
    "build:preload": "vite build --config vite.preload.config.mjs",
    "build": "npm run build:renderer && npm run build:main && npm run build:preload",
    "dist": "npm run build && electron-builder",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:win": "npm run build && electron-builder --win",
    "dist:linux": "npm run build && electron-builder --linux",
    "publish": "npm run build && electron-builder --publish always"
  },
  "keywords": [],
  "author": {
    "name": "Suja",
    "email": "sujarahaman.dms.727@gmail.com"
  },
  "license": "MIT",
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "concurrently": "^9.2.1",
    "electron": "36.5.0",
    "electron-builder": "^26.8.1",
    "tailwindcss": "^4.2.1",
    "vite": "^5.4.19",
    "wait-on": "^9.0.4"
  },
  "dependencies": {
    "@radix-ui/react-alert-dialog": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@vitejs/plugin-react": "^4.5.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "electron-store": "^10.1.0",
    "electron-updater": "^6.8.3",
    "ffmpeg-static": "^5.2.0",
    "ffprobe-static": "^3.1.0",
    "lucide-react": "^0.542.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "tailwind-merge": "^3.5.0",
    "tailwindcss-animate": "^1.0.7"
  }
}
